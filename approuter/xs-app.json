{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "responseHeaders": [
    { "name": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
  ],
  "routes": [
    {
      "source": "^/chat/(.*)$",
      "target": "/chat/$1",
      "destination": "cap-backend",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/odata/v4/(.*)$",
      "target": "/odata/v4/$1",
      "destination": "cap-backend",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "destination": "cap-backend",
      "authenticationType": "xsuaa"
    }
  ]
}