{
  "welcomeFile": "/index.html",
  "authenticationMethod": "none",
  "routes": [
    {
      "source": "^/odata/v4/(.*)$",
      "target": "/odata/v4/$1",
      "destination": "cap-backend",
      "authenticationType": "none"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "destination": "cap-backend",
      "authenticationType": "none"
    }
  ]
}