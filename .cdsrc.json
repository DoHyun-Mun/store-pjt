{
  "requires": {
    "db": {
      "kind": "sql"
    },
    "auth": {
      "kind": "dummy"
    }
  },
  "[production]": {
    "requires": {
      "db": {
        "kind": "hana"
      }
    }
  },
  "hana": {
    "deploy-format": "hdbtable"
  },
  "log": {
    "levels": {
      "deploy": "error",
      "db": "error",
      "sql": "error",
      "sqlite": "error",
      "cds": "warn"
    }
  }
}